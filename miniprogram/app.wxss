/* app.wxss - 全局样式 */
page {
  background: linear-gradient(180deg, #FFF5EB 0%, #F5F5F5 30%);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  color: #333333;
  font-size: 28rpx;
  box-sizing: border-box;
}

view, text, image {
  box-sizing: border-box;
}

.container {
  padding: 24rpx 32rpx;
  padding-bottom: 180rpx;
}

/* 积分星星单位 */
.star-unit {
  font-size: 0.55em;
  vertical-align: middle;
  margin-left: 4rpx;
}

/* 通用卡片 */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

/* 通用按钮 */
.btn-primary {
  background: linear-gradient(135deg, #FF9500, #FF8C00);
  color: #ffffff;
  border-radius: 44rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}

.btn-primary::after {
  border: none;
}

.btn-outline {
  background: #ffffff;
  color: #FF8C00;
  border: 2rpx solid #FF8C00;
  border-radius: 44rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-outline::after {
  border: none;
}

.btn-small {
  height: 56rpx;
  line-height: 56rpx;
  font-size: 24rpx;
  border-radius: 28rpx;
  padding: 0 24rpx;
}

/* 等级颜色 */
.grade-a-plus {
  background: #E8F5E9;
  color: #4CAF50;
}

.grade-a {
  background: #E3F2FD;
  color: #2196F3;
}

.grade-b {
  background: #FFF8E1;
  color: #FF9800;
}

.grade-d {
  background: #FFEBEE;
  color: #F44336;
}

/* 标签 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-green {
  background: #E8F5E9;
  color: #4CAF50;
}

.tag-blue {
  background: #E3F2FD;
  color: #2196F3;
}

.tag-orange {
  background: #FFF3E0;
  color: #FF8C00;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  color: #999999;
  font-size: 28rpx;
}

/* 分隔线 */
.divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 20rpx 0;
}

/* 导航栏右侧 */
.nav-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

/* ===== 表单通用样式 ===== */
.form-group { margin-bottom: 32rpx; }
.form-label { font-size: 30rpx; font-weight: 700; color: #333333; margin-bottom: 16rpx; display: block; }
.form-input {
  background: #F5F5F5;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
}
.form-textarea {
  background: #F5F5F5;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  width: 100%;
  min-height: 160rpx;
}

/* 图标选择网格 */
.icon-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 16rpx;
}
.icon-item {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  border-radius: 16rpx;
  background: #F5F5F5;
  border: 3rpx solid transparent;
  transition: all 0.2s ease;
}
.icon-item.selected {
  border-color: #FF8C00;
  background: #FFF3E0;
}

/* 表单操作按钮 */
.form-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 48rpx;
}
.btn-cancel {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  background: #F5F5F5;
  color: #666666;
}
.btn-save {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #FF9500, #FF8C00);
  color: #ffffff;
}

/* 未登录提示（全局复用） */
.login-required {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}
.login-required-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}
.login-required-text {
  font-size: 30rpx;
  color: #999999;
  margin-bottom: 40rpx;
}
.login-required-btn {
  padding: 20rpx 64rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #FF9500, #FF8C00);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
}
