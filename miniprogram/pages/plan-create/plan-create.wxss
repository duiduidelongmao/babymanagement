.form-group { margin-bottom: 32rpx; }
.form-label { font-size: 30rpx; font-weight: 700; color: #333333; margin-bottom: 16rpx; }

.form-input {
  background: #F5F5F5;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
}

.form-textarea {
  background: #F5F5F5;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  width: 100%;
  min-height: 160rpx;
}

.icon-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 16rpx;
}

.icon-item {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  border-radius: 16rpx;
  background: #F5F5F5;
  border: 3rpx solid transparent;
  transition: all 0.2s ease;
}

.icon-item.selected {
  border-color: #FF8C00;
  background: #FFF3E0;
}

.form-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 48rpx;
}

.btn-cancel {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  background: #F5F5F5;
  color: #666666;
}

.btn-save {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #FF9500, #FF8C00);
  color: #ffffff;
}
