/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 44rpx;
  padding: 16rpx 28rpx;
  margin-bottom: 24rpx;
}

.search-icon {
  font-size: 28rpx;
  color: #999999;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

/* 分类标签 */
.category-scroll {
  margin-bottom: 24rpx;
}

.category-list {
  display: flex;
  gap: 16rpx;
  padding: 4rpx 0;
}

.category-item {
  flex-shrink: 0;
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666666;
  background: #ffffff;
  border: 2rpx solid #e0e0e0;
}

.category-item.active {
  background: #FF8C00;
  color: #ffffff;
  border-color: #FF8C00;
}

/* 常用入口 */
.section-label {
  font-size: 26rpx;
  color: #666666;
  font-weight: 600;
  margin-bottom: 16rpx;
  padding-left: 4rpx;
}

.common-entry {
  display: flex;
  align-items: center;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.entry-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  background: #E3F2FD;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.entry-content {
  flex: 1;
}

.entry-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.entry-desc {
  font-size: 24rpx;
  color: #999999;
}

.entry-arrow {
  font-size: 32rpx;
  color: #cccccc;
}

/* FAQ 列表 */
.faq-list {
  margin-bottom: 32rpx;
}

.faq-item {
  margin-bottom: 16rpx;
  overflow: hidden;
}

.faq-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx;
}

.faq-question {
  flex: 1;
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
  line-height: 1.4;
}

.faq-arrow {
  font-size: 32rpx;
  color: #999999;
  transition: transform 0.3s ease;
  transform: rotate(90deg);
}

.faq-arrow.open {
  transform: rotate(-90deg);
}

.faq-body {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease;
}

.faq-body.show {
  max-height: 500rpx;
}

.faq-answer {
  padding: 0 28rpx 28rpx;
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}

/* 底部联系方式 */
.contact-section {
  margin-top: 32rpx;
}

.contact-label {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 16rpx;
  padding-left: 4rpx;
}

.contact-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.contact-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.contact-phone {
  font-size: 32rpx;
  font-weight: 700;
  color: #4CAF50;
}

.contact-copy {
  font-size: 28rpx;
  color: #FF8C00;
  font-weight: 600;
}
