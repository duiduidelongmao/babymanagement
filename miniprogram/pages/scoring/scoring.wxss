/* 孩子选择器 */
.child-selector { display: flex; align-items: center; margin-bottom: 20rpx; }
.child-icon-wrap { width: 72rpx; height: 72rpx; border-radius: 50%; background: #FFF5EB; display: flex; align-items: center; justify-content: center; margin-right: 16rpx; }
.child-icon { font-size: 40rpx; }
.child-name { display: flex; align-items: baseline; gap: 8rpx; }
.name-text { font-size: 36rpx; font-weight: 700; color: #FF8C00; }
.name-label { font-size: 28rpx; color: #FF8C00; }
.child-arrow { font-size: 20rpx; color: #FF8C00; margin-left: 8rpx; }

/* 记录日期 */
.date-card { display: flex; align-items: center; justify-content: space-between; padding: 20rpx 28rpx; margin-bottom: 20rpx; }
.date-label { font-size: 26rpx; color: #999999; }
.date-value { font-size: 28rpx; font-weight: 600; color: #FF8C00; }

/* 当前积分 */
.points-card { text-align: center; padding: 32rpx 0; margin-bottom: 20rpx; }
.points-label { font-size: 26rpx; color: #999999; margin-bottom: 8rpx; }
.points-value { font-size: 72rpx; font-weight: 800; color: #333333; }
.points-unit { font-size: 32rpx; font-weight: 600; color: #FF8C00; margin-left: 4rpx; }

/* 今日收入/支出 */
.today-stats { display: flex; align-items: center; margin-bottom: 24rpx; }
.today-stat-item { flex: 1; display: flex; align-items: center; justify-content: center; gap: 12rpx; padding: 20rpx 0; }
.today-stat-divider { width: 1rpx; height: 60rpx; background: #f0f0f0; }
.today-stat-dot { width: 16rpx; height: 16rpx; border-radius: 50%; flex-shrink: 0; }
.income-dot { background: #4CAF50; }
.expense-dot { background: #F44336; }
.today-stat-info { display: flex; flex-direction: column; align-items: center; gap: 4rpx; }
.today-stat-label { font-size: 26rpx; color: #666666; }
.today-stat-value { font-size: 36rpx; font-weight: 700; }
.today-stat-value.positive { color: #4CAF50; }
.today-stat-value.negative { color: #F44336; }

/* 计分入口按钮 */
.entry-row { display: flex; gap: 20rpx; margin-bottom: 24rpx; }
.entry-btn {
  flex: 1; display: flex; align-items: center; justify-content: center; gap: 8rpx;
  padding: 24rpx 0; border-radius: 20rpx; font-size: 28rpx; font-weight: 600;
}
.entry-icon { font-size: 32rpx; }
.entry-free { background: #E8F5E9; border: 2rpx solid #4CAF50; color: #4CAF50; }
.entry-quick { background: #FFF3E0; border: 2rpx solid #FF8C00; color: #FF8C00; }

/* 项目列表 */
.habit-list { margin-bottom: 24rpx; }
.habit-item { display: flex; align-items: center; padding: 24rpx 28rpx; margin-bottom: 16rpx; }
.habit-item.scored { background: #FFF8F0; border: 2rpx solid #FFE0B2; }
.habit-icon-small { font-size: 40rpx; width: 64rpx; height: 64rpx; display: flex; align-items: center; justify-content: center; background: #FFF5EB; border-radius: 16rpx; margin-right: 16rpx; }
.habit-info { flex: 1; }
.habit-name { font-size: 30rpx; font-weight: 600; color: #333333; margin-bottom: 4rpx; }
.habit-desc { font-size: 22rpx; color: #999999; }
.habit-right { display: flex; align-items: center; gap: 12rpx; flex-shrink: 0; }
.habit-grade { padding: 4rpx 14rpx; border-radius: 8rpx; font-size: 22rpx; font-weight: 600; color: #ffffff; }
.habit-grade.grade-a-plus { background: #4CAF50; }
.habit-grade.grade-a { background: #2196F3; }
.habit-grade.grade-b { background: #FF9800; }
.habit-grade.grade-d { background: #F44336; }

.habit-pts { font-size: 28rpx; font-weight: 700; }
.habit-pts.grade-a-plus { color: #4CAF50; }
.habit-pts.grade-a { color: #2196F3; }
.habit-pts.grade-b { color: #FF9800; }
.habit-pts.grade-d { color: #F44336; }

/* 底部提示 */
.list-tip { text-align: center; padding: 24rpx 0; font-size: 26rpx; color: #999999; }
.tip-link { color: #FF8C00; font-weight: 500; }

/* ===== 等级选择弹窗 ===== */
.grade-modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 100; display: flex; align-items: center; justify-content: center; padding: 40rpx; }
.grade-modal { background: #ffffff; border-radius: 32rpx; padding: 40rpx 32rpx; width: 100%; max-width: 640rpx; }

/* 弹窗头部 */
.modal-header { text-align: center; margin-bottom: 32rpx; }
.modal-icon { font-size: 48rpx; margin-bottom: 8rpx; }
.modal-title { font-size: 36rpx; font-weight: 700; color: #333333; margin-bottom: 8rpx; }
.modal-desc { font-size: 26rpx; color: #999999; }

/* 等级卡片网格 */
.grade-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20rpx; margin-bottom: 24rpx; }
.grade-card { border-radius: 24rpx; padding: 28rpx; display: flex; flex-direction: column; gap: 6rpx; position: relative; }
.grade-card-top { display: flex; align-items: flex-start; justify-content: space-between; }
.grade-card-letter { font-size: 44rpx; font-weight: 800; }
.grade-card-menu { width: 44rpx; height: 44rpx; border-radius: 50%; background: #ffffff; display: flex; align-items: center; justify-content: center; font-size: 20rpx; color: #999999; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08); }
.grade-card-label { font-size: 26rpx; color: #666666; }
.grade-card-score { font-size: 30rpx; font-weight: 700; }

/* A+ 卡片 */
.grade-card.grade-a-plus { background: #E8F5E9; }
.grade-card.grade-a-plus .grade-card-letter { color: #4CAF50; }
.grade-card.grade-a-plus .grade-card-score { color: #4CAF50; }
.grade-card.grade-a-plus.selected { box-shadow: 0 0 0 4rpx #4CAF50; }

/* A 卡片 */
.grade-card.grade-a { background: #E3F2FD; }
.grade-card.grade-a .grade-card-letter { color: #2196F3; }
.grade-card.grade-a .grade-card-score { color: #2196F3; }
.grade-card.grade-a.selected { box-shadow: 0 0 0 4rpx #2196F3; }

/* B 卡片 */
.grade-card.grade-b { background: #FFF8E1; }
.grade-card.grade-b .grade-card-letter { color: #FF9800; }
.grade-card.grade-b .grade-card-score { color: #FF9800; }
.grade-card.grade-b.selected { box-shadow: 0 0 0 4rpx #FF9800; }

/* D 卡片 */
.grade-card.grade-d { background: #FFEBEE; }
.grade-card.grade-d .grade-card-letter { color: #F44336; }
.grade-card.grade-d .grade-card-score { color: #F44336; }
.grade-card.grade-d.selected { box-shadow: 0 0 0 4rpx #F44336; }

/* 弹窗底部提示 */
.modal-tip { display: flex; align-items: flex-start; gap: 12rpx; padding: 16rpx 20rpx; background: #FFF8F0; border-radius: 16rpx; }
.modal-tip-icon { font-size: 28rpx; color: #FF8C00; flex-shrink: 0; }
.modal-tip-text { font-size: 24rpx; color: #999999; line-height: 1.5; }