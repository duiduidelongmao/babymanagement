.profile-avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
  padding-top: 20rpx;
}

.avatar-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}
.avatar-wrapper::after { border: none; }

.profile-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid #FF8C00;
}

.profile-avatar-emoji {
  font-size: 96rpx;
  width: 160rpx;
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFF5EB;
  border-radius: 50%;
  border: 4rpx solid #FF8C00;
}

.avatar-hint {
  font-size: 22rpx;
  color: #FF8C00;
  margin-top: 12rpx;
}

.info-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  margin-bottom: 12rpx;
}

.info-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  width: 140rpx;
  flex-shrink: 0;
}

.info-input {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #666666;
}

.info-value-readonly {
  flex: 1;
  text-align: right;
  font-size: 26rpx;
  color: #999999;
}

.logout-section {
  margin-top: 60rpx;
}

.logout-btn {
  text-align: center;
  padding: 28rpx 0;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #F44336;
  background: #FFEBEE;
}
