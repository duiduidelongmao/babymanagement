.detail-header {
  margin-bottom: 16rpx;
}

.detail-title {
  font-size: 48rpx;
  font-weight: 800;
  color: #333333;
}

.detail-date-range {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

/* 时间筛选器 */
.time-filter {
  display: flex;
  white-space: nowrap;
  margin-bottom: 24rpx;
}

.filter-item {
  display: inline-flex;
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #666666;
  background: #ffffff;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.filter-item.active {
  background: #FF8C00;
  color: #ffffff;
  font-weight: 600;
}

/* 统计卡片 */
.stats-card {
  background: #FFF8F0;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.stats-main {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.stats-label {
  font-size: 24rpx;
  color: #999999;
}

.stats-value {
  font-size: 64rpx;
  font-weight: 800;
}

.stats-value.positive { color: #4CAF50; }
.stats-value.negative { color: #F44336; }

.stats-count {
  font-size: 26rpx;
  color: #999999;
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 40rpx;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stats-item-label {
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.stats-item-value {
  font-size: 32rpx;
  font-weight: 700;
}

.stats-item-value.positive { color: #4CAF50; }
.stats-item-value.negative { color: #F44336; }

.stats-divider {
  width: 2rpx;
  height: 60rpx;
  background: #E0E0E0;
}

/* 记录列表 */
.record-list {
  margin-bottom: 32rpx;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
}

.record-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #FFF5EB;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.record-icon {
  font-size: 36rpx;
}

.record-info {
  flex: 1;
  min-width: 0;
}

.record-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.record-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.record-date {
  font-size: 24rpx;
  color: #999999;
}

.record-tag {
  font-size: 22rpx;
  color: #FF8C00;
  background: #FFF3E0;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.record-score {
  font-size: 36rpx;
  font-weight: 700;
  margin-left: 16rpx;
}

.record-score.positive { color: #4CAF50; }
.record-score.negative { color: #F44336; }

.empty-state {
  text-align: center;
  padding: 80rpx 0;
  color: #999999;
  font-size: 28rpx;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}