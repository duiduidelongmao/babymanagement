/* 协议头部 */
.agreement-header {
  margin-bottom: 32rpx;
}

.agreement-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 12rpx;
}

.agreement-date {
  font-size: 26rpx;
  color: #999999;
}

/* 协议简介 */
.agreement-intro {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.7;
  margin-bottom: 40rpx;
}

/* 协议章节 */
.agreement-section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 16rpx;
}

.section-paragraph {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.7;
  margin-bottom: 16rpx;
}

.section-paragraph:last-child {
  margin-bottom: 0;
}
