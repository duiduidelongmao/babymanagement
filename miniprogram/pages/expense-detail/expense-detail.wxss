/* 净值卡片 */
.net-card { padding: 32rpx; margin-bottom: 20rpx; position: relative; }
.net-label { font-size: 26rpx; color: #666666; margin-bottom: 8rpx; }
.net-value { font-size: 72rpx; font-weight: 800; }
.net-value.positive { color: #4CAF50; }
.net-value.negative { color: #F44336; }
.net-count { position: absolute; right: 32rpx; top: 50%; transform: translateY(-50%); font-size: 26rpx; color: #999999; }

/* 汇总行 */
.summary-row { display: flex; margin-bottom: 20rpx; }
.summary-item { flex: 1; display: flex; align-items: center; justify-content: space-between; padding: 20rpx 28rpx; }
.summary-item:first-child { border-right: 1rpx solid #f0f0f0; }
.summary-label { font-size: 28rpx; color: #666666; }
.summary-value { font-size: 32rpx; font-weight: 700; }
.summary-value.positive { color: #4CAF50; }
.summary-value.negative { color: #F44336; }

/* 记录列表 */
.record-list { margin-bottom: 24rpx; }
.record-item { display: flex; align-items: center; padding: 24rpx 28rpx; margin-bottom: 16rpx; }
.record-icon { font-size: 40rpx; width: 64rpx; height: 64rpx; display: flex; align-items: center; justify-content: center; background: #FFF5EB; border-radius: 16rpx; margin-right: 16rpx; flex-shrink: 0; }
.record-info { flex: 1; min-width: 0; }
.record-name { font-size: 30rpx; font-weight: 600; color: #333333; margin-bottom: 6rpx; }
.record-meta { display: flex; align-items: center; gap: 12rpx; flex-wrap: wrap; }
.record-time { font-size: 22rpx; color: #999999; }
.record-grade { padding: 2rpx 10rpx; border-radius: 6rpx; font-size: 20rpx; font-weight: 600; }
.record-grade.grade-a-plus { background: #E8F5E9; color: #4CAF50; }
.record-grade.grade-a { background: #E3F2FD; color: #2196F3; }
.record-grade.grade-b { background: #FFF8E1; color: #FF9800; }
.record-grade.grade-d { background: #FFEBEE; color: #F44336; }
.record-grade.grade-free { background: #FFF3E0; color: #FF8C00; }
.record-desc { font-size: 22rpx; color: #999999; }
.record-score { font-size: 32rpx; font-weight: 700; flex-shrink: 0; }
.record-score.positive { color: #4CAF50; }
.record-score.negative { color: #F44336; }

/* 空状态 */
.empty-state { text-align: center; padding: 80rpx 0; font-size: 28rpx; color: #999999; }
.empty-icon { font-size: 48rpx; margin-bottom: 12rpx; }