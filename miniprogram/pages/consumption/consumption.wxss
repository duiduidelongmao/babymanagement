.page-header { margin-bottom: 20rpx; }
.page-title { font-size: 48rpx; font-weight: 800; color: #333333; }

/* 积分汇总 */
.points-card { padding: 32rpx; margin-bottom: 24rpx; }

.points-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.points-label { font-size: 28rpx; color: #999999; }
.points-value { font-size: 56rpx; font-weight: 800; color: #FF8C00; }

.points-spent {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #FFF8F0;
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
}

.spent-text { font-size: 24rpx; color: #999999; }
.spent-value { font-size: 28rpx; font-weight: 700; color: #F44336; }
.spent-link { font-size: 24rpx; color: #FF8C00; margin-left: auto; }

/* 操作按钮 */
.action-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.action-add {
  background: #ffffff;
  border: 2rpx solid #FF8C00;
  color: #FF8C00;
}

.action-deduct {
  background: linear-gradient(135deg, #FF9500, #FF8C00);
  color: #ffffff;
}

/* 奖励网格 */
.reward-grid {
  display: flex;
  flex-wrap: wrap;
}

.reward-card {
  width: calc(50% - 10rpx);
  padding: 24rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.reward-card:nth-child(odd) {
  margin-right: 20rpx;
}

.reward-manage {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 8rpx;
}

.manage-btn {
  font-size: 20rpx;
  color: #999999;
  padding: 4rpx 12rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.manage-delete { color: #F44336; background: #FFEBEE; }

.reward-icon { font-size: 56rpx; margin-bottom: 8rpx; }
.reward-name { font-size: 28rpx; font-weight: 600; color: #333333; margin-bottom: 4rpx; }
.reward-desc { font-size: 20rpx; color: #999999; margin-bottom: 8rpx; }
.reward-pts { font-size: 28rpx; font-weight: 700; color: #FF8C00; margin-bottom: 12rpx; }

.redeem-btn {
  display: inline-flex;
  padding: 8rpx 32rpx;
  border: 2rpx solid #FF8C00;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #FF8C00;
  font-weight: 500;
}

.redeem-btn:active { background: #FFF3E0; }

/* 扣减弹窗 */
.deduct-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.deduct-mask.show { opacity: 1; visibility: visible; }

.deduct-popup {
  width: 600rpx;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 40rpx 32rpx;
  transform: scale(0.8);
  transition: all 0.3s ease;
}

.deduct-popup.show { transform: scale(1); }

.deduct-title {
  text-align: center;
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 32rpx;
}

.deduct-field {
  margin-bottom: 24rpx;
}

.deduct-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 12rpx;
}

.deduct-input {
  background: #F5F5F5;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
}

.deduct-date-picker {
  background: #F5F5F5;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #FF8C00;
}

.deduct-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.deduct-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.deduct-btn.cancel {
  background: #F5F5F5;
  color: #666666;
}

.deduct-btn.confirm {
  background: linear-gradient(135deg, #FF9500, #FF8C00);
  color: #ffffff;
}
