<view class="container">
  <!-- 图标分类 -->
  <scroll-view class="category-tabs" scroll-x="true">
    <view class="cat-tab {{currentCategory === item ? 'active' : ''}}"
      wx:for="{{categories}}" wx:key="*this" wx:for-item="item"
      bindtap="onCategoryChange" data-cat="{{item}}">{{item}}</view>
  </scroll-view>

  <!-- 图标选择 -->
  <view class="icon-grid">
    <view class="icon-item {{selectedIcon === item ? 'selected' : ''}}"
      wx:for="{{filteredIcons}}" wx:key="*this" wx:for-item="item"
      bindtap="onIconSelect" data-icon="{{item}}">
      {{item}}
    </view>
  </view>

  <!-- 奖励名称 -->
  <view class="form-group">
    <view class="form-label">奖励名称</view>
    <input class="form-input" placeholder="如：去游乐园" value="{{name}}" bindinput="onNameInput" />
  </view>

  <!-- 所需积分 -->
  <view class="form-group">
    <view class="form-label">所需积分</view>
    <input class="form-input" type="number" value="{{points}}" bindinput="onPointsInput" />
  </view>

  <!-- 说明 -->
  <view class="form-group">
    <view class="form-label">说明</view>
    <textarea class="form-textarea" placeholder="可选" value="{{description}}" bindinput="onDescInput" maxlength="200" />
  </view>

  <!-- 保存 -->
  <view class="btn-save-full" bindtap="onSave">保存</view>
</view>
