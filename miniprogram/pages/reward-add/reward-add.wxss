.category-tabs { display: flex; white-space: nowrap; margin-bottom: 24rpx; }
.cat-tab {
  display: inline-flex;
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #666666;
  background: #ffffff;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.cat-tab.active { background: #FF8C00; color: #ffffff; font-weight: 600; }

.icon-grid {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 32rpx;
}

.icon-item {
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  border-radius: 16rpx;
  background: #F5F5F5;
  border: 3rpx solid transparent;
}

.icon-item.selected { border-color: #FF8C00; background: #FFF3E0; }

.form-group { margin-bottom: 28rpx; }
.form-label { font-size: 28rpx; font-weight: 700; color: #333333; margin-bottom: 12rpx; }
.form-input { background: #F5F5F5; border-radius: 16rpx; padding: 24rpx; font-size: 28rpx; }
.form-textarea { background: #F5F5F5; border-radius: 16rpx; padding: 24rpx; font-size: 28rpx; width: 100%; min-height: 120rpx; }

.btn-save-full {
  background: linear-gradient(135deg, #FF9500, #FF8C00);
  color: #ffffff;
  text-align: center;
  padding: 28rpx 0;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 32rpx;
}
