/* 顶部标签 */
.detail-header {
  margin-bottom: 24rpx;
}

.detail-tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 24rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #2196F3;
  background: #E3F2FD;
}

/* 高亮卡片 */
.highlight-card {
  margin-bottom: 32rpx;
}

.highlight-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 16rpx;
}

.highlight-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.7;
}

/* 区块标题 */
.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 20rpx;
  margin-top: 32rpx;
}

/* 步骤列表 */
.step-list {
  margin-bottom: 24rpx;
}

.step-item {
  display: flex;
  align-items: flex-start;
  padding: 28rpx;
  margin-bottom: 16rpx;
}

.step-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  background: #FFF3E0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.step-body {
  flex: 1;
}

.step-label {
  font-size: 24rpx;
  color: #FF8C00;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.step-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.step-desc {
  font-size: 26rpx;
  color: #999999;
  line-height: 1.5;
}

/* 关系卡片 */
.relation-card {
  margin-bottom: 32rpx;
}

.relation-flow {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 32rpx;
  padding: 16rpx 0;
}

.relation-node {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.relation-emoji {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  background: #FFF5EB;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.relation-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.relation-arrow {
  font-size: 36rpx;
  color: #cccccc;
  font-weight: 700;
}

.relation-desc-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.relation-desc-item {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}

.relation-keyword {
  font-weight: 700;
  color: #333333;
}
