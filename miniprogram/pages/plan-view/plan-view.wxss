.plan-header {
  display: flex;
  gap: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.plan-icon {
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFF5EB;
  border-radius: 50%;
  font-size: 48rpx;
  flex-shrink: 0;
}

.plan-title-wrap {
  flex: 1;
}

.plan-title-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.plan-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
}

.plan-badge {
  font-size: 22rpx;
  color: #FF8C00;
  background: #FFF5EB;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.plan-edit-btn {
  font-size: 24rpx;
  color: #FF8C00;
  background: #FFF5EB;
  padding: 6rpx 20rpx;
  border-radius: 12rpx;
  margin-left: auto;
}

.plan-desc {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.plan-tags {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  align-items: center;
}

.plan-tag-wrap {
  display: flex;
  align-items: center;
  position: relative;
}

.plan-tag {
  font-size: 24rpx;
  color: #666666;
  background: #F5F5F5;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

.tag-delete {
  font-size: 20rpx;
  color: #F44336;
  margin-left: 6rpx;
  padding: 2rpx 8rpx;
}

.count-tag {
  color: #FF8C00;
  background: #FFF5EB;
}

/* 细项列表 */
.items-section {
  margin-bottom: 120rpx;
}

.add-item-row {
  display: flex;
  justify-content: center;
  margin-bottom: 24rpx;
}

.add-item-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 40rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #FF8C00;
  background: #FFF5EB;
  border: 2rpx dashed #FF8C00;
}

.item-card {
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.item-header {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
  align-items: flex-start;
}

.item-icon {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFF5EB;
  border-radius: 50%;
  font-size: 36rpx;
  flex-shrink: 0;
}

.item-title-wrap {
  flex: 1;
}

.item-title-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 6rpx;
}

.item-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333333;
}

.item-freq {
  font-size: 22rpx;
  color: #999999;
  background: #F5F5F5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.item-desc {
  font-size: 26rpx;
  color: #666666;
}

.item-actions {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex-shrink: 0;
}

.item-action-btn {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  text-align: center;
}

.item-action-btn.edit {
  color: #FF8C00;
  background: #FFF5EB;
}

.item-action-btn.delete {
  color: #F44336;
  background: #FFEBEE;
}

/* 等级分值 */
.item-grades {
  display: flex;
  gap: 16rpx;
}

.grade-pill {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.grade-a-plus { background: #E8F5E9; color: #4CAF50; }
.grade-a { background: #E3F2FD; color: #2196F3; }
.grade-b { background: #FFF8E1; color: #FF9800; }
.grade-d { background: #FFEBEE; color: #F44336; }

/* 底部按钮 */
.bottom-action {
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.use-btn {
  text-align: center;
  padding: 28rpx 0;
  background: linear-gradient(135deg, #FF9500, #FF8C00);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
}

/* 编辑弹窗 */
.edit-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.edit-mask.show { opacity: 1; visibility: visible; }

.edit-popup {
  width: 640rpx;
  max-height: 80vh;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 40rpx 32rpx;
  transform: scale(0.8);
  transition: all 0.3s ease;
  overflow-y: auto;
}

.edit-popup.show { transform: scale(1); }

.edit-popup-title {
  text-align: center;
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 32rpx;
}

.edit-field {
  margin-bottom: 24rpx;
}

.edit-field-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 12rpx;
}

.edit-field-input {
  background: #F5F5F5;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
}

.score-inputs {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.score-input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.score-input-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  width: 60rpx;
  flex-shrink: 0;
}

.score-input-field {
  flex: 1;
  background: #F5F5F5;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
}

.edit-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.edit-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.edit-btn.cancel {
  background: #F5F5F5;
  color: #666666;
}

.edit-btn.confirm {
  background: linear-gradient(135deg, #FF9500, #FF8C00);
  color: #ffffff;
}

/* 图标选择器 */
.icon-cat-tabs {
  display: flex;
  white-space: nowrap;
  margin-top: 16rpx;
  margin-bottom: 16rpx;
}

.icon-cat-tab {
  display: inline-flex;
  padding: 10rpx 24rpx;
  border-radius: 28rpx;
  font-size: 24rpx;
  color: #666666;
  background: #F5F5F5;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.icon-cat-tab.active {
  background: #FF8C00;
  color: #ffffff;
  font-weight: 600;
}

.icon-picker-wrap {
  display: flex;
  flex-wrap: wrap;
}

.icon-picker-item {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  border-radius: 16rpx;
  background: #F5F5F5;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  border: 3rpx solid transparent;
}

.icon-picker-item.selected {
  border-color: #FF8C00;
  background: #FFF3E0;
}
