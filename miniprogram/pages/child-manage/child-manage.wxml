<view class="container">
  <!-- 孩子列表 -->
  <view class="child-list">
    <view class="child-item card" wx:for="{{children}}" wx:key="id">
      <view class="child-avatar">{{item.avatar}}</view>
      <view class="child-info">
        <view class="child-name">{{item.name}}</view>
        <view class="child-points">积分：{{item.totalPoints}}</view>
      </view>
      <view class="child-actions">
        <view class="action-edit" catchtap="onEditChild" data-id="{{item.id}}">编辑</view>
        <view class="action-delete" catchtap="onDeleteChild" data-id="{{item.id}}" wx:if="{{children.length > 1}}">删除</view>
      </view>
    </view>
  </view>

  <!-- 添加孩子 -->
  <view class="add-child-btn" bindtap="onAddChild">+ 添加孩子</view>

  <!-- 添加/编辑弹窗 -->
  <view class="form-mask {{showForm ? 'show' : ''}}" bindtap="onFormCancel">
    <view class="form-popup {{showForm ? 'show' : ''}}" catchtap="preventBubble">
      <view class="form-title">{{isEditChild ? '编辑孩子' : '添加孩子'}}</view>

      <view class="form-group">
        <view class="form-label">名字</view>
        <input class="form-input" placeholder="输入孩子名字" value="{{editName}}" bindinput="onNameInput" focus="{{showForm}}" />
      </view>

      <view class="form-group">
        <view class="form-label">头像</view>
        <view class="avatar-grid">
          <view class="avatar-option {{editAvatar === item ? 'selected' : ''}}"
            wx:for="{{avatarList}}" wx:key="*this" wx:for-item="item"
            bindtap="onAvatarSelect" data-avatar="{{item}}">
            {{item}}
          </view>
        </view>
      </view>

      <view class="form-actions">
        <view class="btn-cancel" bindtap="onFormCancel">取消</view>
        <view class="btn-save" bindtap="onFormSave">保存</view>
      </view>
    </view>
  </view>
</view>
