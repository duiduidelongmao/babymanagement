.page-header {
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.child-selector {
  display: flex;
  align-items: center;
}

.child-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #FFF5EB;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.child-icon {
  font-size: 40rpx;
}

.child-name {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.name-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #FF8C00;
}

.child-arrow {
  font-size: 20rpx;
  color: #FF8C00;
}

.date-range {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.join-family-btn {
  font-size: 26rpx;
  color: #FF8C00;
  background: #FFF3E0;
  padding: 12rpx 24rpx;
  border-radius: 28rpx;
  font-weight: 500;
}

/* 时间筛选器 */
.time-filter {
  display: flex;
  white-space: nowrap;
  margin-bottom: 24rpx;
}

.filter-item {
  display: inline-flex;
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #666666;
  background: #ffffff;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.filter-item.active {
  background: #FF8C00;
  color: #ffffff;
  font-weight: 600;
}

/* 净值卡片 */
.net-value-card {
  background: #FFF8F0;
  padding: 32rpx;
}

.net-label {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 16rpx;
}

/* 趋势图卡片 */
.trend-card {
  background: #ffffff;
  padding: 24rpx;
}

.trend-label {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 12rpx;
}

.trend-canvas {
  width: 100%;
  height: 140rpx;
}

.net-row-three {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.net-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.net-col-main {
  align-items: flex-start;
  flex: 1.2;
}

.net-col-label {
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.net-col-value {
  font-size: 32rpx;
  font-weight: 700;
}

.net-col-value-large {
  font-size: 56rpx;
  font-weight: 800;
}

.net-col-value.positive { color: #4CAF50; }
.net-col-value.negative { color: #F44336; }

.net-col-divider {
  width: 2rpx;
  height: 60rpx;
  background: #E0E0E0;
}

/* 数据视图 Tab */
.data-tabs {
  display: flex;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 6rpx;
  margin-bottom: 24rpx;
}

.data-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #999999;
  border-radius: 16rpx;
  transition: all 0.2s ease;
}

.data-tab.active {
  background: #ffffff;
  color: #333333;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

/* 数据内容 */
.data-content {
  min-height: 300rpx;
}

/* 分类累计 */
.category-card {
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
}

.category-card-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.category-card-info {
  flex: 1;
  min-width: 0;
}

.category-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
}

.category-bar-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.category-bar-bg {
  height: 8rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
}

.category-bar {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.category-values {
  display: flex;
  gap: 24rpx;
  font-size: 22rpx;
}

.category-arrow {
  font-size: 40rpx;
  color: #cccccc;
  margin-left: 16rpx;
  font-weight: 300;
}

.val-positive { color: #4CAF50; font-weight: 600; }
.val-negative { color: #F44336; font-weight: 600; }
.val-count { color: #999999; }

/* 评分统计 */
.grade-card {
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
}

.grade-card-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.grade-card-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
  min-width: 0;
}

.grade-stat-badge {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.grade-stat-badge.grade-a-plus { background: #E8F5E9; }
.grade-stat-badge.grade-a { background: #E3F2FD; }
.grade-stat-badge.grade-b { background: #FFF8E1; }
.grade-stat-badge.grade-d { background: #FFEBEE; }

.grade-stat-letter {
  font-size: 24rpx;
  font-weight: 800;
}

.grade-a-plus .grade-stat-letter { color: #4CAF50; }
.grade-a .grade-stat-letter { color: #2196F3; }
.grade-b .grade-stat-letter { color: #FF9800; }
.grade-d .grade-stat-letter { color: #F44336; }

.grade-card-info {
  flex: 1;
  min-width: 0;
}

.grade-bar-bg {
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}

.grade-bar {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.grade-count {
  font-size: 24rpx;
  color: #666666;
}

.grade-arrow {
  font-size: 40rpx;
  color: #cccccc;
  margin-left: 16rpx;
  font-weight: 300;
}

/* 每日变化 */
.daily-item { padding: 24rpx 28rpx; margin-bottom: 16rpx; }

.daily-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.daily-date {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.daily-net {
  font-size: 32rpx;
  font-weight: 700;
}
.daily-net.positive { color: #4CAF50; }
.daily-net.negative { color: #F44336; }

.daily-bars {
  display: flex;
  gap: 16rpx;
}

.daily-bar {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.income-bar {
  background: #E8F5E9;
  color: #4CAF50;
}

.expense-bar {
  background: #FFEBEE;
  color: #F44336;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

/* 加入家庭弹窗 */
.join-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.join-mask.show {
  opacity: 1;
  visibility: visible;
}

.join-popup {
  width: 560rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  text-align: center;
}

.join-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 12rpx;
}

.join-subtitle {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 40rpx;
}

.join-input {
  background: #F5F5F5;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  font-size: 32rpx;
  text-align: center;
  letter-spacing: 8rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 40rpx;
}

.join-actions {
  display: flex;
  gap: 20rpx;
}

.join-btn-cancel {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  background: #F5F5F5;
  color: #666666;
}

.join-btn-confirm {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #FF9500, #FF8C00);
  color: #ffffff;
}
