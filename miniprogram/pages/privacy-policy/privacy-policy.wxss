/* 政策头部 */
.policy-header {
  margin-bottom: 32rpx;
}

.policy-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 12rpx;
}

.policy-date {
  font-size: 26rpx;
  color: #999999;
}

/* 政策简介 */
.policy-intro {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.7;
  margin-bottom: 40rpx;
}

/* 政策章节 */
.policy-section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 16rpx;
}

.section-paragraph {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.7;
  margin-bottom: 16rpx;
}

.section-paragraph:last-child {
  margin-bottom: 0;
}
