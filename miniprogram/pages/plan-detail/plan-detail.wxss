/* Tab 切换 */
.tab-bar {
  display: flex;
  padding: 8rpx;
  margin-bottom: 24rpx;
  border-radius: 48rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 30rpx;
  color: #666666;
  border-radius: 40rpx;
}

.tab-item.active {
  background: linear-gradient(135deg, #FF9500, #FF8C00);
  color: #ffffff;
  font-weight: 600;
}

/* 我的规则 */
.rule-card {
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.rule-header {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.rule-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFF5EB;
  border-radius: 50%;
  font-size: 40rpx;
  flex-shrink: 0;
}

.rule-info {
  flex: 1;
}

.rule-name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.rule-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
}

.rule-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.rule-status.active {
  background: #E8F5E9;
  color: #4CAF50;
}

.rule-status.inactive {
  background: #F5F5F5;
  color: #999999;
}

.rule-desc {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
}

.rule-toggle {
  flex-shrink: 0;
}

.rule-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #f5f5f5;
}

.rule-count {
  font-size: 26rpx;
  color: #666666;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.count-icon {
  font-size: 20rpx;
  color: #FF8C00;
}

.rule-actions {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.rule-detail {
  font-size: 28rpx;
  color: #FF8C00;
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.rule-delete {
  font-size: 28rpx;
  color: #F44336;
  font-weight: 500;
  padding: 8rpx 16rpx;
}

.arrow {
  font-size: 32rpx;
}

/* 模板库 */
.tpl-card {
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.tpl-header {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.tpl-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFF5EB;
  border-radius: 50%;
  font-size: 40rpx;
  flex-shrink: 0;
}

.tpl-info {
  flex: 1;
}

.tpl-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.tpl-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
}

.tpl-count {
  font-size: 26rpx;
  color: #666666;
  background: #F5F5F5;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
}

.tpl-desc {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.tpl-tags {
  display: flex;
  gap: 12rpx;
}

.tpl-tag {
  font-size: 24rpx;
  color: #FF8C00;
  background: #FFF5EB;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

.tpl-footer {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f5f5f5;
}

.tpl-action {
  font-size: 28rpx;
  color: #333333;
  padding: 12rpx 24rpx;
}

.tpl-primary {
  background: linear-gradient(135deg, #FF9500, #FF8C00);
  color: #ffffff;
  border-radius: 32rpx;
  padding: 16rpx 40rpx;
  font-weight: 600;
}

.tpl-added {
  color: #999999;
}

/* 新建按钮 */
.create-btn {
  text-align: center;
  padding: 28rpx 0;
  margin-top: 20rpx;
  color: #FF8C00;
  font-size: 30rpx;
  font-weight: 600;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.empty-state {
  text-align: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}
