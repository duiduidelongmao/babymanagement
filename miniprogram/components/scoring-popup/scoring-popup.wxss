.scoring-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.scoring-mask.show {
  opacity: 1;
  visibility: visible;
}

.scoring-popup {
  width: 600rpx;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 40rpx 32rpx;
  transform: scale(0.8);
  transition: all 0.3s ease;
}

.scoring-popup.show {
  transform: scale(1);
}

.popup-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.popup-icon {
  font-size: 64rpx;
  margin-bottom: 12rpx;
}

.popup-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 8rpx;
}

.popup-desc {
  font-size: 24rpx;
  color: #999999;
}

.grade-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.grade-card {
  border-radius: 20rpx;
  padding: 28rpx 20rpx;
  text-align: center;
  position: relative;
  transition: transform 0.15s ease;
}

.grade-card:active {
  transform: scale(0.95);
}

.grade-a-plus {
  background: #E8F5E9;
}

.grade-a {
  background: #E3F2FD;
}

.grade-b {
  background: #FFF8E1;
}

.grade-d {
  background: #FFEBEE;
}

.grade-letter {
  font-size: 44rpx;
  font-weight: 800;
  margin-bottom: 4rpx;
}

.grade-a-plus .grade-letter { color: #4CAF50; }
.grade-a .grade-letter { color: #2196F3; }
.grade-b .grade-letter { color: #FF9800; }
.grade-d .grade-letter { color: #F44336; }

.grade-label {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 8rpx;
}

.grade-score {
  font-size: 28rpx;
  font-weight: 700;
}

.grade-a-plus .grade-score { color: #4CAF50; }
.grade-a .grade-score { color: #2196F3; }
.grade-b .grade-score { color: #FF9800; }
.grade-d .grade-score { color: #F44336; }

.popup-tip {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  background: #FFF8E1;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
}

.tip-icon {
  font-size: 28rpx;
  color: #FF9800;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.tip-text {
  font-size: 22rpx;
  color: #999999;
  line-height: 1.6;
}
