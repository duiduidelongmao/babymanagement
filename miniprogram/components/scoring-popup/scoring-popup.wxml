<view class="scoring-mask {{visible ? 'show' : ''}}" bindtap="onMaskTap">
  <view class="scoring-popup {{visible ? 'show' : ''}}" catchtap="preventBubble">
    <!-- 标题区 -->
    <view class="popup-header">
      <view class="popup-icon">{{item.icon}}</view>
      <view class="popup-title">{{item.name}}</view>
      <view class="popup-desc">{{item.description}}</view>
    </view>

    <!-- 评分等级卡 2x2 -->
    <view class="grade-grid">
      <view class="grade-card grade-a-plus" bindtap="onGradeTap" data-grade="A" data-score="{{gradeAPlus.score}}">
        <view class="grade-letter">A</view>
        <view class="grade-label">{{gradeAPlus.label}}</view>
        <view class="grade-score">+{{gradeAPlus.score}}分</view>
      </view>
      <view class="grade-card grade-a" bindtap="onGradeTap" data-grade="B" data-score="{{gradeA.score}}">
        <view class="grade-letter">B</view>
        <view class="grade-label">{{gradeA.label}}</view>
        <view class="grade-score">+{{gradeA.score}}分</view>
      </view>
      <view class="grade-card grade-b" bindtap="onGradeTap" data-grade="C" data-score="{{gradeB.score}}">
        <view class="grade-letter">C</view>
        <view class="grade-label">{{gradeB.label}}</view>
        <view class="grade-score">{{gradeB.score}}分</view>
      </view>
      <view class="grade-card grade-d" bindtap="onGradeTap" data-grade="D" data-score="{{gradeD.score}}">
        <view class="grade-letter">D</view>
        <view class="grade-label">{{gradeD.label}}</view>
        <view class="grade-score">{{gradeD.score}}分</view>
      </view>
    </view>

    <!-- 提示 -->
    <view class="popup-tip">
      <text class="tip-icon">ⓘ</text>
      <text class="tip-text">点击等级卡即可按默认分值快速计分；长按等级卡可临时修改本次得分。</text>
    </view>
  </view>
</view>
